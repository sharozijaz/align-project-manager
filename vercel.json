{
  "crons": [
    {
      "path": "/api/cron/sync-google-calendar",
      "schedule": "0 5 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/google-todos/status",
      "destination": "/api/google-todos?action=status"
    },
    {
      "source": "/api/google-todos/settings",
      "destination": "/api/google-todos?action=settings"
    },
    {
      "source": "/api/google-todos/sync",
      "destination": "/api/google-todos?action=sync"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/mobile-auth.html",
      "destination": "/mobile-auth.html"
    },
    {
      "source": "/mobile-auth",
      "destination": "/mobile-auth.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
