# Align local development
# Copy to .env.local and fill only what you need.

# Local-only mode:
# Leave all values empty. Align stores data on this device.

# Optional Supabase Auth + workspace sync
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_ALLOWED_EMAILS=

# Optional hosted app/API origin
VITE_APP_URL=
VITE_PUBLIC_APP_URL=

# Optional Google client metadata for hosted Google sync
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=
VITE_GOOGLE_CALENDAR_ID=primary
