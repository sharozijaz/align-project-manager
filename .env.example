# Align local-first defaults
# Leave cloud values empty if you only want local device storage.

# Frontend-safe optional Supabase config
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_ALLOWED_EMAILS=
# google | magic_link | both. Production defaults to google when unset.
VITE_AUTH_METHOD=

# Frontend-safe app/public URL config
# VITE_APP_URL is the hosted app/API origin for browser builds.
# VITE_PUBLIC_APP_URL is the public origin used for share links from desktop builds.
VITE_APP_URL=
VITE_PUBLIC_APP_URL=

# Frontend-safe optional Google config
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=
VITE_GOOGLE_CALENDAR_ID=primary

# Server-only hosted API config
APP_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ALLOWED_API_ORIGINS=

# Server-only optional Google sync config
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_CALENDAR_ID=primary
GOOGLE_TOKEN_ENCRYPTION_KEY=

# Server-only optional cron/email reminder config
CRON_SECRET=
RESEND_API_KEY=
REMINDER_EMAIL_FROM=
REMINDER_EMAIL_REPLY_TO=
