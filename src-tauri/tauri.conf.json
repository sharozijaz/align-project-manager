{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Align",
  "version": "0.1.0",
  "identifier": "dev.sharoz.align",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Align",
        "width": 1440,
        "height": 900,
        "minWidth": 980,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Sharoz Ijaz",
    "shortDescription": "Align project management",
    "longDescription": "Align is a focused project management workspace for freelance web design and development.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
